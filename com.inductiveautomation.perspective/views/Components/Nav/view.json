{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "width": 1440,
      "height": 56
    }
  },
  "root": {
    "meta": {
      "name": "root"
    },
    "type": "ia.container.flex",
    "props": {
      "direction": "row",
      "style": {
        "backgroundColor": "#0D1526",
        "borderBottom": "1px solid #1B2B4B",
        "alignItems": "center",
        "padding": "0 24px",
        "height": "56px",
        "gap": "0px"
      }
    },
    "children": [
      {
        "meta": {
          "name": "Logo"
        },
        "type": "ia.display.label",
        "position": {
          "basis": "220px",
          "shrink": 0
        },
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tsystem.perspective.navigate('/')"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "props": {
          "text": "POWERGRID HMI",
          "style": {
            "fontSize": "15px",
            "fontWeight": "700",
            "color": "#4F8EF7",
            "letterSpacing": "2px",
            "cursor": "pointer"
          }
        }
      },
      {
        "meta": {
          "name": "NavTabs"
        },
        "type": "ia.container.flex",
        "position": {
          "grow": 1
        },
        "props": {
          "direction": "row",
          "style": {
            "alignItems": "center",
            "gap": "4px"
          }
        },
        "children": [
          {
            "meta": {
              "name": "TabHome"
            },
            "type": "ia.display.label",
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tsystem.perspective.navigate('/')"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "propConfig": {
              "props.style.backgroundColor": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({page.props.path}='/','#1B2B4B','transparent')"
                  }
                }
              },
              "props.style.color": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({page.props.path}='/','#E2E8F0','#94A3B8')"
                  }
                }
              },
              "props.style.fontWeight": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({page.props.path}='/','600','500')"
                  }
                }
              }
            },
            "props": {
              "text": "Home",
              "style": {
                "padding": "6px 16px",
                "fontSize": "13px",
                "fontWeight": "600",
                "color": "#E2E8F0",
                "backgroundColor": "#1B2B4B",
                "borderRadius": "6px",
                "cursor": "pointer"
              }
            }
          },
